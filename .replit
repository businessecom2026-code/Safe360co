run = "npm install && npm run build && npm run start:replit"
entrypoint = "server.ts"
modules = ["nodejs-20", "web", "nix"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "gce"
run = ["sh", "-c", "npm install && npm run build && npm run start:replit"]
publicDir = "dist/public"
ignorePorts = true

[[ports]]
localPort = 3000
externalPort = 80
