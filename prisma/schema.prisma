generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  role             String    @default("admin") // 'master' | 'admin' | 'guest'
  plan             String?   @default("Free")  // 'Free' | 'Pro' | 'Scale'
  planExpiresAt    DateTime?
  invitedBy        String?   // FK to User.id (not enforced — avoids circular dep)
  inviteToken      String?   @unique
  activated        Boolean   @default(false)
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())

  vaults          Vault[]
  activityLogs    ActivityLog[]
  backupSnapshots BackupSnapshot[]

  @@index([email])
  @@index([inviteToken])
  @@index([resetToken])
}

// ─── Vaults ──────────────────────────────────────────────────────────────────

model Vault {
  id        String   @id @default(uuid())
  name      String
  userId    String
  color     String   @default("#6366f1")
  status    String   @default("active")  // 'active' | 'pending'
  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders Folder[]
  items   VaultItem[]

  @@index([userId])
  @@index([userId, status])
}

// ─── Folders (nested via Adjacency List) ─────────────────────────────────────

model Folder {
  id        String   @id @default(uuid())
  vaultId   String
  parentId  String?  // null = root folder of vault
  name      String
  color     String   @default("#6366f1")
  icon      String   @default("Folder")  // lucide icon key
  createdAt DateTime @default(now())

  vault    Vault     @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  parent   Folder?   @relation("FolderChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children Folder[]  @relation("FolderChildren")
  items    VaultItem[]

  @@index([vaultId])
  @@index([vaultId, parentId])
}

// ─── Vault Items ─────────────────────────────────────────────────────────────

model VaultItem {
  id           String   @id @default(uuid())
  vaultId      String
  folderId     String?  // null = root of vault
  type         String   @default("note") // 'password' | 'note' | 'media'
  status       String   @default("active") // 'active' | 'pending' (guest submissions)
  title        String
  passwords    Json     @default("[]") // PasswordField[] — AES-GCM encrypted values
  note         String?
  attachment   Json?    // VaultItemAttachment { name, size, mimeType, data }
  mediaRef     String?
  mediaPinHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vault  Vault   @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([vaultId])
  @@index([vaultId, folderId])
  @@index([vaultId, status])
}

// ─── Activity Logs ───────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  ip        String?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

// ─── Backup Snapshots ────────────────────────────────────────────────────────

model BackupSnapshot {
  id        String   @id @default(uuid())
  userId    String
  payload   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
